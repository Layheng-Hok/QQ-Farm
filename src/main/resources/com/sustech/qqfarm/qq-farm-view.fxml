<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sustech.qqfarm.client.QqFarmController"
            prefHeight="480.0" prefWidth="650.0">
    <top>
        <VBox spacing="10" alignment="CENTER" style="-fx-background-color: #ddd; -fx-padding: 10;">
            <Label text="QQ Farm" textFill="#333">
                <font>
                    <Font size="24.0"/>
                </font>
            </Label>
            <HBox spacing="20" alignment="CENTER">
                <Label fx:id="lblUser" text="Farm Owner: --" style="-fx-font-weight: bold;"/>
                <Label fx:id="lblCoins" text="Coins: --" textFill="#d35400"/>
            </HBox>
            <Label fx:id="lblMessage" text="Ready" textFill="#555"/>
        </VBox>
    </top>
    <center>
        <GridPane fx:id="gridFarm" alignment="CENTER" hgap="0" vgap="0"
                  style="-fx-padding: 0; -fx-background-color: #F2BE7D;">
        </GridPane>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER" style="-fx-padding: 15; -fx-background-color: #ddd;">
            <VBox spacing="5" alignment="CENTER">
                <Label text="Farm Navigation" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                <HBox spacing="10">
                    <Button fx:id="btnMyFarm" text="My Farm" onAction="#onMyFarmClick"
                            style="-fx-focus-color: transparent; -fx-faint-focus-color: transparent;"/>
                    <TextField fx:id="txtFriendName" promptText="Friend's Name" prefWidth="120"/>
                    <Button text="Visit" onAction="#onVisitClick"/>
                </HBox>
            </VBox>
            <Separator orientation="VERTICAL"/>
            <VBox spacing="5" alignment="CENTER">
                <Label text="Actions (Select Plot First)" style="-fx-font-size: 10px; -fx-text-fill: #666;"/>
                <HBox spacing="10">
                    <Button fx:id="btnPlant" text="Plant" onAction="#onPlantClick" disable="true"
                            style="-fx-base: #a2d9a2;"/>
                    <Button fx:id="btnHarvest" text="Harvest" onAction="#onHarvestClick" disable="true"
                            style="-fx-base: #ffd700;"/>
                    <Button fx:id="btnSteal" text="Steal" onAction="#onStealClick" disable="true"
                            style="-fx-base: #ff6b6b;"/>
                </HBox>
            </VBox>
        </HBox>
    </bottom>
</BorderPane>
